#!/bin/bash

# ==================================================
# Default Konfigurasi
# ==================================================
INTERVAL=1
PIDFILE="/tmp/ydotool_clicker.pid"
SOCKET_PATH="/run/user/$UID/.ydotool_socket"
TOGGLE=0
CLEANED_UP=0

# ==================================================
# Argument Parsing
# ==================================================
CLICK_MODE="left"

while [[ $# -gt 0 ]]; do
  case "$1" in
  left | right)
    CLICK_MODE="$1"
    shift
    ;;
  --interval | -i)
    INTERVAL="$2"
    shift 2
    ;;
  *)
    echo "Usage: $0 [left|right] [--interval <seconds>]"
    exit 1
    ;;
  esac
done

# ==================================================
# Validasi Interval
# ==================================================
if ! [[ "$INTERVAL" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
  echo "ERROR: interval must be a number (e.g. 0.1)"
  exit 1
fi

# ==================================================
# Click Mode Mapping
# ==================================================
case "$CLICK_MODE" in
left) CLICK_CODE="0xC0" ;;
right) CLICK_CODE="0xC1" ;;
esac

# ==================================================
# Auto Cleanup ydotool
# ==================================================
cleanup_ydotool() {
  echo "Cleaning ydotool..."
  if [ -S "$SOCKET_PATH" ]; then
    sudo pkill -f "ydotoold.*$SOCKET_PATH" 2>/dev/null
    rm -f "$SOCKET_PATH"
  fi
}

# ==================================================
# Start ydotoold
# ==================================================
start_ydotoold() {
  cleanup_ydotool

  echo "Starting ydotoold..."
  mkdir -p "/run/user/$UID"

  sudo ydotoold \
    --socket-path="$SOCKET_PATH" \
    --socket-own="$UID:$GID" \
    >/dev/null 2>&1 &

  for _ in {1..20}; do
    [ -S "$SOCKET_PATH" ] && {
      echo "ydotoold started successfully"
      return 0
    }
    sleep 0.3
  done

  echo "ERROR: Failed to start ydotoold"
  exit 1
}

# ==================================================
# Toggle Handler
# ==================================================
toggle_click() {
  TOGGLE=$((1 - TOGGLE))
  if ((TOGGLE == 1)); then
    echo "Autoclicker ON ($CLICK_MODE, interval=${INTERVAL}s)"
  else
    echo "Autoclicker OFF"
  fi
}

# ==================================================
# Exit Cleanup (Idempotent)
# ==================================================
cleanup_exit() {
  ((CLEANED_UP == 1)) && return
  CLEANED_UP=1

  echo "Exiting autoclicker..."
  cleanup_ydotool
  rm -f "$PIDFILE"
  exit 0
}

# ==================================================
# Signal Handling
# ==================================================
trap "toggle_click" SIGUSR1
trap "cleanup_exit" SIGINT SIGTERM EXIT

# ==================================================
# Init
# ==================================================
echo $$ >"$PIDFILE"
start_ydotoold

cat <<EOF
Autoclicker ready
PID      : $$
Mode     : $CLICK_MODE
Interval : ${INTERVAL}s
Socket   : $SOCKET_PATH
Toggle   : F8
Status   : OFF
EOF

# ==================================================
# Main Loop
# ==================================================
while true; do
  if ((TOGGLE == 1)); then
    if [ -S "$SOCKET_PATH" ]; then
      YDOTOOL_SOCKET="$SOCKET_PATH" \
        ydotool click "$CLICK_CODE" &>/dev/null
    else
      echo "Socket lost, restarting ydotoold..."
      start_ydotoold
    fi
  fi
  sleep "$INTERVAL"
done
