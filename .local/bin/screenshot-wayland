#!/usr/bin/env bash

set -euo pipefail

DIR="$HOME/Pictures/Screenshots"
mkdir -p "$DIR"

FILENAME="$(date +"%Y-%m-%d_%H%M%S").png"
FULLPATH=$DIR/$FILENAME

if [[ ${XDG_SESSION_TYPE:-} != "wayland" ]]; then
  notify-send "Session must wayland"
fi

if ! command -v grim >/dev/null; then
  notify-send "Package grim not installed" "Please install it first"
  exit
fi

if grim "$FULLPATH"; then
  notify-send -i "$FULLPATH" "Screenshot Successful" "Saved in $FULLPATH"
else
  notify-send "Screenshots failed" "An error occurred while taking a screenshot"
fi
