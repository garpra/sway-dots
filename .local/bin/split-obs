#!/bin/bash

# =========================================================
# OBS Bedrock Split Script
# Output:
#   videos/recording/<name>_game.mp4
#   videos/recording/<name>_mic.mp3
# =========================================================

set -e

if [ $# -lt 1 ]; then
  echo "Usage: $0 <recording.mkv>"
  exit 1
fi

INPUT="$1"

if [ ! -f "$INPUT" ]; then
  echo "Error: File not found -> $INPUT"
  exit 1
fi

BASENAME="$(basename "$INPUT" .mkv)"

# Target directory
OUTDIR="/home/gilang/Videos/Recording"

# Create directory if not exists
mkdir -p "$OUTDIR"

VIDEO_OUT="$OUTDIR/${BASENAME}_game.mp4"
MIC_OUT="$OUTDIR/${BASENAME}_mic.mp3"

echo "▶ Input : $INPUT"
echo "📁 Out  : $OUTDIR"

# ---------------------------------------------------------
# 1. Video + Game Audio (copy, no re-encode)
# ---------------------------------------------------------
ffmpeg -y \
  -i "$INPUT" \
  -map 0:v:0 \
  -map 0:a:0 \
  -c copy \
  "$VIDEO_OUT"

# ---------------------------------------------------------
# 2. Mic Audio → MP3
# ---------------------------------------------------------
ffmpeg -y \
  -i "$INPUT" \
  -map 0:a:1 \
  -vn \
  -c:a libmp3lame \
  -b:a 192k \
  "$MIC_OUT"

echo "✅ Done"
echo "🎮 Video : $VIDEO_OUT"
echo "🎤 Mic   : $MIC_OUT"
