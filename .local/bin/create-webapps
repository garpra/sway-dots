#!/bin/bash

# Minta input dari user
read -p "Application Name: " APP_NAME
read -p "Application URL: " APP_URL
read -p "Icon URL (PNG): " ICON_URL

# Cek apakah ada input kosong
if [ -z "$APP_NAME" ] || [ -z "$APP_URL" ] || [ -z "$ICON_URL" ]; then
  echo "All inputs must be filled in."
  exit 1
fi

# Tentukan lokasi penyimpanan
ICON_DIR="$HOME/.local/share/applications/icons"
DESKTOP_FILE="$HOME/.local/share/applications/$APP_NAME.desktop"

# Buat folder icon jika belum ada
mkdir -p "$ICON_DIR"

# Download icon
ICON_PATH="$ICON_DIR/$APP_NAME.png"
curl -L "$ICON_URL" -o "$ICON_PATH"

# Buat file .desktop
cat >"$DESKTOP_FILE" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=$APP_NAME
Exec=chromium --app="$APP_URL"
Icon=$ICON_PATH
Terminal=false
EOF

# Jadikan file bisa dijalankan
chmod +x "$DESKTOP_FILE"

echo "Application '$APP_NAME' was created successfully."
