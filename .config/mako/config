# Layout & Position 
anchor=top-right
margin=12
padding=12,16
width=360
height=120
border-size=2
border-radius=8

# Behaviour 
max-visible=5
max-history=20
default-timeout=6000
ignore-timeout=0
sort=-time
layer=overlay

# Typography 
font=0xProto Nerd Font 11

# Format 
# Tampilkan app-name, judul tebal, lalu body
format=<b>%s</b>\n%b

# TokyoNight Storm — Default (normal urgency) 
background-color=#15161e
text-color=#c0caf5
border-color=#7aa2f7
progress-color=over #3b4261

# Urgency: Low 
[urgency=low]
background-color=#15161e
text-color=#737aa2
border-color=#3b4261
default-timeout=4000

# Urgency: Normal 
[urgency=normal]
background-color=#15161e
text-color=#c0caf5
border-color=#7aa2f7
default-timeout=6000

# Urgency: Critical 
[urgency=critical]
background-color=#15161e
text-color=#f7768e
border-color=#f7768e
default-timeout=0

# Grouped notifications 
[grouped]
format=(%g) <b>%s</b>\n%b
border-color=#bb9af7

# Hidden overflow indicator 
[hidden]
format=(%h more)
text-color=#737aa2
border-color=#3b4261

# Do Not Disturb mode 
# Aktifkan: makoctl mode -a do-not-disturb
# Nonaktifkan: makoctl mode -r do-not-disturb
[mode=do-not-disturb]
invisible=1

# App-specific overrides 
# Warna hijau untuk notif sukses (misal dari git, build tools)
[app-name=notify-send urgency=low]
border-color=#9ece6a

# Warna kuning untuk warning
[urgency=normal app-name=dunst]
border-color=#e0af68
