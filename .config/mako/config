# Layout & Position
anchor=top-right
margin=12
padding=12,16
width=360
height=120
border-size=2
border-radius=3

# Behaviour
max-visible=5
max-history=20
default-timeout=6000
ignore-timeout=0
sort=-time
layer=overlay

# Typography
font=0xProto Nerd Font 11

# Format
format=<b>%s</b>\n%b

# TokyoNight Night — Default (normal urgency)
background-color=#1a1b26
text-color=#c0caf5
border-color=#7aa2f7
progress-color=over #292e42

# Urgency: Low
[urgency=low]
background-color=#1a1b26
text-color=#565f89
border-color=#292e42
default-timeout=4000

# Urgency: Normal
[urgency=normal]
background-color=#1a1b26
text-color=#c0caf5
border-color=#7aa2f7
default-timeout=6000

# Urgency: Critical
[urgency=critical]
background-color=#1a1b26
text-color=#f7768e
border-color=#f7768e
default-timeout=0

# Grouped notifications
[grouped]
format=(%g) <b>%s</b>\n%b
border-color=#bb9af7

# Hidden overflow indicator
[hidden]
format=(%h more)
text-color=#565f89
border-color=#292e42

# Do Not Disturb mode
[mode=do-not-disturb]
invisible=1

# App-specific overrides
[app-name=notify-send urgency=low]
border-color=#9ece6a
[urgency=normal app-name=dunst]
border-color=#e0af68
